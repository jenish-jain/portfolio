---
layout: bento.njk
title: Jenish Jain's Engineering Blog
seo_title: Jenish Jain | Engineering Blog | Software Engineer at Rapido
description: Engineering insights, system design tutorials, and tech experiences by Jenish Jain. Learn about software engineering, system design, Apache Kafka, and more.
---

<main class="home-page">

  <!-- Hero -->
  <section class="home-hero">
    <div class="hero-kicker">/engineering blog</div>
    <h1 class="hero-title">Writing about <em>systems</em>,<br>tools, and the craft<br>of building software.</h1>
    <p class="hero-sub">Posts on distributed systems, Go, cloud infrastructure, and anything else worth sharing.</p>
    <a href="/posts/" class="hero-cta">read all posts →</a>
  </section>


  <!-- Recent posts grid -->
  <section class="home-recent">
    <div class="recent-label">/recent posts</div>
    <div class="recent-grid">
      {% for post in collections.posts | limit(5) %}
        {% if post.data.url %}
          {% set postHref = post.data.url %}
          {% set isExternal = true %}
        {% else %}
          {% set postHref = "/" + post.data.slug + "/" %}
          {% set isExternal = false %}
        {% endif %}
        <a class="post-card {% if loop.index === 1 %}post-card--featured{% endif %}"
           href="{{ postHref }}"{% if isExternal %} target="_blank" rel="noopener noreferrer"{% endif %}>
          <div class="post-card-cat">{{ post.data.category }}</div>
          <div class="post-card-title">{{ post.data.title }}</div>
          {% if loop.index === 1 %}
          <p class="post-card-desc">{{ post.data.description }}</p>
          {% endif %}
          <div class="post-card-meta">{{ post.date | simpleDate }}</div>
        </a>
      {% endfor %}
    </div>
    <a href="/posts/" class="view-all">view all {{ collections.posts | length }} posts →</a>
  </section>

</main>

<style>
  .home-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px) 80px;
  }

  /* Hero */
  .home-hero {
    padding: clamp(48px, 8vw, 96px) 0 clamp(48px, 6vw, 72px);
    border-bottom: 1px solid var(--hair);
    max-width: 820px;
  }
  .hero-kicker {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .hero-kicker::before {
    content: "";
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 1px;
  }
  .hero-title {
    font-family: var(--display);
    font-size: clamp(44px, 7vw, 88px);
    line-height: 1.0;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 0 0 28px;
    color: var(--ink);
  }
  .hero-title em {
    font-style: italic;
    color: var(--accent-2);
  }
  .hero-sub {
    font-size: 18px;
    line-height: 1.6;
    color: var(--muted);
    max-width: 52ch;
    margin: 0 0 36px;
  }
  .hero-cta {
    display: inline-block;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 24px;
    background: var(--ink);
    color: var(--paper);
    border-radius: 999px;
    text-decoration: none;
    transition: background .2s, box-shadow .2s;
  }
  .hero-cta:hover {
    background: var(--accent);
    color: var(--ink);
    box-shadow: 0 6px 18px rgba(255,231,66,0.35);
  }

  /* Recent posts */
  .home-recent { padding-top: clamp(40px, 5vw, 60px); }
  .recent-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .recent-label::before {
    content: "";
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 1px;
  }

  .recent-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 160px;
    gap: 12px;
  }
  @media (max-width: 760px) {
    .recent-grid { grid-template-columns: 1fr; grid-auto-rows: auto; }
  }

  .post-card {
    background: var(--tile);
    border: 1px solid var(--hair);
    border-radius: 18px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: transform .3s cubic-bezier(.2,.7,.2,1), box-shadow .3s;
    overflow: hidden;
  }
  .post-card:hover { transform: translateY(-3px); box-shadow: 0 14px 32px rgba(0,0,0,0.08); }

  /* Featured card — spans 7 cols, 2 rows */
  .post-card--featured {
    grid-column: span 7;
    grid-row: span 2;
    background: var(--ink);
    color: var(--paper);
  }
  /* Cards 2–3 stack on the right: each 5 cols, 1 row */
  .post-card:nth-child(2) { grid-column: span 5; }
  .post-card:nth-child(3) { grid-column: span 5; }
  /* Cards 4–5 fill the bottom row: 4 cols each */
  .post-card:nth-child(4) { grid-column: span 4; }
  .post-card:nth-child(5) { grid-column: span 4; }

  @media (max-width: 760px) {
    .post-card, .post-card--featured,
    .post-card:nth-child(2), .post-card:nth-child(3),
    .post-card:nth-child(4), .post-card:nth-child(5) {
      grid-column: 1;
      grid-row: auto;
    }
  }

  .post-card-cat {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .post-card-cat::before {
    content: "";
    width: 5px;
    height: 5px;
    background: var(--accent);
    border-radius: 1px;
    flex-shrink: 0;
  }
  .post-card--featured .post-card-cat { color: rgba(243,237,225,0.5); }

  .post-card-title {
    font-family: var(--display);
    font-size: clamp(18px, 2vw, 26px);
    line-height: 1.1;
    margin: 0 0 auto;
    color: var(--ink);
  }
  .post-card--featured .post-card-title {
    font-size: clamp(28px, 3.5vw, 46px);
    color: var(--paper);
  }

  .post-card-desc {
    font-size: 14px;
    line-height: 1.55;
    color: rgba(243,237,225,0.7);
    margin: 14px 0 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-meta {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-top: 12px;
    text-transform: uppercase;
  }
  .post-card--featured .post-card-meta { color: rgba(243,237,225,0.45); }

  .view-all {
    display: inline-block;
    margin-top: 24px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    border-bottom: 1px solid var(--hair);
    padding-bottom: 2px;
    transition: color .18s, border-color .18s;
  }
  .view-all:hover { color: var(--ink); border-color: var(--ink); }
</style>
