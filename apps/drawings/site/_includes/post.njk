<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <link rel="apple-touch-icon" sizes="152x152" href="{{ '/apple-touch-icon.png' | url }}" />
    <link rel="icon" type="image/png" sizes="32x32" href="{{ '/favicon-32x32.png' | url }}" />
    <link rel="icon" type="image/png" sizes="16x16" href="{{ '/favicon-16x16.png' | url }}" />
    <link rel="manifest" href="{{ '/site.webmanifest' | url }}" />
    <meta name="msapplication-TileColor" content="#ffe742" />
    <meta name="theme-color" content="#ffe742" />

    <title>{{ title }} — Jenish Jain</title>
    <link rel="canonical" href="{{ siteUrl }}/{{ slug }}/" />
    <meta name="author" content="Jenish Jain" />
    <meta name="description" content="{{ description if description else title }}" />
    {% if thumb %}
    <meta name="image" content="{{ thumb }}" />
    <meta property="og:image" content="{{ thumb }}" />
    <meta name="twitter:image" content="{{ thumb }}" />
    {% endif %}
    <meta property="og:type" content="article" />
    <meta property="og:url" content="{{ siteUrl }}/{{ slug }}/" />
    <meta property="og:title" content="{{ title }}" />
    <meta name="twitter:dnt" content="on" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@jenishjain6" />

    <link rel="alternate" type="application/rss+xml" title="RSS Feed" href="/feed.xml" />

    <style>
      :root {
        --paper:    #efeae0;
        --tile:     #f7f3ea;
        --tile-2:   #ece4d2;
        --ink:      #15120e;
        --ink-soft: #2b2620;
        --muted:    #837a6d;
        --hair:     rgba(21,18,14,0.12);
        --accent:   #ffe742;
        --accent-2: #1f3df1;
        --display:  "Instrument Serif", "Times New Roman", serif;
        --sans:     "Geist", system-ui, sans-serif;
        --mono:     "JetBrains Mono", ui-monospace, monospace;
        --radius:   22px;
      }

      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--paper);
        color: var(--ink);
        font-family: var(--sans);
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
        overflow-x: hidden;
      }
      a { color: inherit; text-decoration: none; }
      ::selection { background: var(--accent); color: var(--ink); }

      /* ── Top bar ── */
      .bento-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px clamp(20px, 4vw, 40px);
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .bento-top .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--ink);
        text-decoration: none;
      }
      .bento-top .brand .dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: var(--accent);
        box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 30%, transparent);
        flex-shrink: 0;
      }
      .bento-top .nav-links {
        display: flex;
        gap: 14px;
        align-items: center;
      }
      .bento-top .nav-links a {
        color: var(--muted);
        padding: 5px 12px;
        border-radius: 999px;
        border: 1px solid transparent;
        transition: color .18s, border-color .18s, background .18s;
      }
      .bento-top .nav-links a:hover {
        color: var(--ink);
        border-color: var(--ink);
        background: var(--accent);
      }

      /* ── Page layout ── */
      .drawing-page {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 clamp(20px, 4vw, 48px) 80px;
      }

      /* ── Breadcrumb ── */
      .breadcrumb {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 36px;
        display: flex;
        gap: 8px;
        align-items: center;
      }
      .breadcrumb a { color: var(--muted); transition: color .15s; }
      .breadcrumb a:hover { color: var(--ink); }
      .breadcrumb .sep { opacity: 0.4; }

      /* ── Drawing header ── */
      .drawing-header {
        margin-bottom: 32px;
      }
      .drawing-header h1 {
        font-family: var(--display);
        font-size: clamp(36px, 5vw, 60px);
        line-height: 1.05;
        font-weight: 400;
        letter-spacing: -0.01em;
        margin: 0 0 16px;
      }
      .drawing-meta-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        padding-bottom: 32px;
        border-bottom: 1px solid var(--hair);
      }
      .pill {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 5px 12px;
        border-radius: 999px;
        border: 1px solid var(--hair);
        background: var(--tile);
        color: var(--muted);
      }
      .pill.cat {
        background: var(--accent);
        border-color: var(--accent);
        color: var(--ink);
      }

      /* ── Drawing content ── */
      .drawing-content img {
        display: block;
        width: 100%;
        max-width: 680px;
        height: auto;
        border-radius: var(--radius);
        border: 1px solid var(--hair);
        margin: 0 auto 24px;
      }
      .drawing-content p {
        font-size: 15px;
        color: var(--muted);
        line-height: 1.6;
        text-align: center;
        margin: 0 0 1em;
      }
      .drawing-content a {
        color: var(--ink);
        text-decoration: underline;
        text-decoration-color: var(--accent);
        text-underline-offset: 3px;
        transition: text-decoration-color .18s;
      }
      .drawing-content a:hover { text-decoration-color: var(--accent-2); }

      /* ── Related drawings ── */
      .related {
        margin-top: 56px;
        padding-top: 48px;
        border-top: 1px solid var(--hair);
      }
      .related-label {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
        margin: 0 0 20px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .related-label::before {
        content: "";
        width: 6px;
        height: 6px;
        background: var(--accent);
        border-radius: 1px;
      }
      .related-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
      }
      @media (max-width: 640px) {
        .related-grid { grid-template-columns: 1fr; }
      }
      .related-card {
        background: var(--tile);
        border: 1px solid var(--hair);
        border-radius: var(--radius);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
        transition: transform .3s cubic-bezier(.2,.7,.2,1), box-shadow .3s;
        aspect-ratio: 3 / 4;
        position: relative;
      }
      .related-card:hover { transform: translateY(-3px); box-shadow: 0 12px 28px rgba(0,0,0,0.1); }
      .related-card img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top center;
        transition: transform .4s cubic-bezier(.2,.7,.2,1);
      }
      .related-card:hover img { transform: scale(1.04); }
      .related-card-info {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        padding: 12px 14px;
        background: linear-gradient(transparent, rgba(21,18,14,0.75));
        color: var(--paper);
      }
      .related-card-title {
        font-family: var(--display);
        font-size: 17px;
        line-height: 1.1;
      }
      .related-card-date {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgba(243,237,225,0.5);
        margin-top: 4px;
      }

      /* ── Footer ── */
      .bento-foot {
        display: flex;
        justify-content: space-between;
        padding: 18px clamp(20px, 4vw, 48px) 60px;
        font-family: var(--mono);
        font-size: 11px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        max-width: 900px;
        margin: 0 auto;
      }
      .bento-foot a { color: var(--muted); text-decoration: none; border-bottom: 1px solid var(--hair); transition: color .18s; }
      .bento-foot a:hover { color: var(--ink); }
    </style>
  </head>
  <body>
    <header class="bento-top">
      <a class="brand" href="/posts/">
        <span class="dot"></span>
        Jenish Jain
      </a>
      <nav class="nav-links">
        <a href="/posts/">drawings</a>
        <a href="https://jenishjain.in" target="_blank" rel="noopener">portfolio ↗</a>
      </nav>
    </header>

    <main class="drawing-page">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/posts/">drawings</a>
        <span class="sep">/</span>
        <span>{{ title }}</span>
      </nav>

      <header class="drawing-header">
        <h1>{{ title }}</h1>
        <div class="drawing-meta-bar">
          <span class="pill cat">{{ category }}</span>
          <span class="pill">{{ date | simpleDate }}</span>
        </div>
      </header>

      <div class="drawing-content">
        {{ content | safe }}
      </div>

      {% set relatedList = collections.posts | relatedDrawings(slug, 3) %}
      {% if relatedList.length > 0 %}
      <aside class="related">
        <div class="related-label">/more drawings</div>
        <div class="related-grid">
          {% for item in relatedList %}
          <a class="related-card" href="/{{ item.data.slug }}/">
            <img src="{{ item.data.thumb }}" alt="{{ item.data.title }}" loading="lazy" />
            <div class="related-card-info">
              <div class="related-card-title">{{ item.data.title }}</div>
              <div class="related-card-date">{{ item.date | simpleDate }}</div>
            </div>
          </a>
          {% endfor %}
        </div>
      </aside>
      {% endif %}
    </main>

    <footer class="bento-foot">
      <span>© Jenish Jain — drawings</span>
      <a href="/feed.xml">RSS</a>
    </footer>
  </body>
</html>
